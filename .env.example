# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

SECRET_KEY=your-super-secret-random-key-change-this
DATABASE_URL=sqlite:///stocks.db

# Get free key at: https://newsapi.org
NEWS_API_KEY=your_newsapi_key_here

# Gmail credentials (use App Password, NOT your real password)
# Guide: myaccount.google.com → Security → 2-Step Verification → App passwords
MAIL_USERNAME=yourgmail@gmail.com
MAIL_PASSWORD=your_16_char_app_password

# Set to 'production' when deploying
FLASK_ENV=development
